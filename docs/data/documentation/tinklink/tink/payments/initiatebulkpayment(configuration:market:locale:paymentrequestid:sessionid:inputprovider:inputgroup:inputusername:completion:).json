ot, the user can choose the provider in a list. If the given parameter is not a valid provider, the user will see an error screen."}]}]},{"name":"inputGroup","content":[{"type":"paragraph","inlineContent":[{"text":"The ","type":"text"},{"type":"codeVoice","code":"groupDisplayName"},{"text":" of a bank group (eg. ","type":"text"},{"type":"codeVoice","code":"Sparkassen"},{"text":"). If provided, the user is taken directly to the branch selection for that group. If the group has no branches, behaves like ","type":"text"},{"type":"codeVoice","code":"inputProvider"},{"text":". If invalid, falls back to standard bank selection.","type":"text"}]}]},{"name":"inputUsername","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Pre-fills the username field for supported providers. Providing this makes most sense if the username is a general username, valid for multiple banks (like a SSN)."}]}]},{"name":"completion","content":[{"type":"paragraph","inlineContent":[{"text":"The block to execute when the One-time Payment Initiation flow finished or if an error occurred.","type":"text"}]}]}],"kind":"parameters"},{"content":[{"text":"Discussion","type":"heading","level":2,"anchor":"discussion"},{"inlineContent":[{"text":"Here’s one way you can start the Bulk Payment Initiation via Tink Link:","type":"text"},{"text":" ","type":"text"},{"text":"First create a configuration with your client ID, redirect URI and base domain.","type":"text"}],"type":"paragraph"},{"code":["let configuration = Configuration(clientID: <#String#>, redirectURI: <#String#>, baseDomain: <#BaseDomain#>)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Second, create a market."}],"type":"paragraph"},{"code":["let market = Market(<#String#>)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Third, create multiple single-payment requests. To create single-payment requests, use the "},{"type":"codeVoice","code":"https:\/\/api.tink.com\/api\/v1\/payments\/requests"},{"type":"text","text":" endpoint that is described in detail in "},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.tink.com\/resources\/payments\/one-time-payments\/initiate-your-first-one-time-payment"},{"type":"text","text":" and the "},{"type":"reference","isActive":true,"identifier":"https:\/\/docs.tink.com\/api#payment\/payment-request\/create-payment-request"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lastly, call "},{"type":"codeVoice","code":"Tink.Payments.initiateBulkPayment"},{"type":"text","text":" method with at least the configuration, the market, the bulk payment request id and a completion handler. It will initialize and return an instance of "},{"type":"codeVoice","code":"UINavigationController"},{"type":"text","text":" with "},{"type":"codeVoice","code":"TinkViewController"},{"type":"text","text":" as a "},{"type":"codeVoice","code":"rootViewController"},{"type":"text","text":". Present the view controller in a preferable way."}]},{"type":"codeListing","syntax":"swift","code":["let tinkViewController = Tink.Payments.initiateBulkPayment(configuration: configuration, market: market, paymentRequestID: bulkPaymentRequestID) { result in","    \/\/ Handle result","}","present(viewController, animated: true)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"After the user has completed or canceled the flow, the completion handler will be called with a result. On successful payment the result will contain an instance of "},{"type":"codeVoice","code":"BulkPaymentRequest.ID"},{"type":"text","text":". If something went wrong the result will contain an error."}]},{"type":"codeListing","syntax":"swift","code":["switch result {","    case .success(let bulkPaymentRequestID):","        \/\/ Handle successful bulkPaymentRequestID","    case .failure(let error):","        \/\/ Handle any errors","}"]}],"kind":"content"}],"variants":[{"paths"