t":"The data types to aggregate from the Provider. Multiple items are allowed."}]}],"name":"refreshableItems"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"One of the options ("},{"type":"codeVoice","code":".single"},{"type":"text","text":", "},{"type":"codeVoice","code":".multi"},{"type":"text","text":", "},{"type":"codeVoice","code":".none"},{"type":"text","text":") which affects whether the end user should be able to select which account to use or not."}]}],"name":"accountDialogType"},{"content":[{"type":"paragraph","inlineContent":[{"text":"The unique name of the provider (eg. ","type":"text"},{"type":"codeVoice","code":"sbab-bankid"},{"text":"). If this is provided, the provider will be chosen for the user. If not, the user can choose the provider in a list. If the given parameter is not a valid provider, the user will see an error screen.","type":"text"}]}],"name":"inputProvider"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"groupDisplayName"},{"type":"text","text":" of a bank group (eg. "},{"type":"codeVoice","code":"Sparkassen"},{"type":"text","text":"). If provided, the user is taken directly to the branch selection for that group. If the group has no branches, behaves like "},{"type":"codeVoice","code":"inputProvider"},{"type":"text","text":". If invalid, falls back to standard bank selection."}]}],"name":"inputGroup"},{"content":[{"inlineContent":[{"type":"text","text":"The block to execute when the Fetching account and transaction data in one flow finished or if an error occurred."}],"type":"paragraph"}],"name":"completion"}]},{"kind":"content","content":[{"level":2,"text":"Return Value","type":"heading","anchor":"return-value"},{"inlineContent":[{"type":"text","text":"An instance of "},{"type":"codeVoice","code":"UINavigationController"},{"type":"text","text":" with "},{"type":"codeVoice","code":"TinkViewController"},{"type":"text","text":" as a "},{"type":"codeVoice","code":"rootViewController"},{"type":"text","text":" ready to run the Reports flow."}],"type":"paragraph"}]},{"kind":"content","content":[{"text":"Discussion","anchor":"discussion","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Here’s one way you can start fetching account and transaction data in one flow via Tink Link:"},{"type":"text","text":" "},{"type":"text","text":"First create a configuration with your client ID, redirect URI and base domain."}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["let configuration = Configuration(clientID: <#String#>, redirectURI: <#String#>, baseDomain: <#BaseDomain#>)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Second, create a market."}]},{"type":"codeListing","syntax":"swift","code":["let market = Market(<#String#>)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Third, specify a report types, a refreshable items and an account dialog type."}]},{"type":"codeListing","syntax":"swift","code":["let reportTypes: ReportTypes = .accountVereficationReport","let refreshableItems: RefreshableItems = [.checkingAccounts, .identityData]","let accountDialogType: AccountDialogType = .single"]},{"type":"paragraph","inlineContent":[{"text":"Lastly, call ","type":"text"},{"code":"Tink.Reports.createReport","type":"codeVoice"},{"text":" method with at least the configuration, the report types, the refreshable items, the account dialog type and a completion handler. It will initialize and return an instance of ","type":"text"},{"code":"UINavigationController","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"TinkViewController","type":"codeVoice"},{"text":" as a ","type":"text"},{"code":"rootViewController","type":"codeVoice"},{"text":". Present the view controller in a preferable way.","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["let viewController = Tink.Reports.createReport(configuration: configuration, reportTypes: reportTypes, refreshableItems: refreshableItems, accountDialogType: accountDialogType) { result in","    \/\/ Handle result","}","present(viewController, animated: true)"]},{"type":"paragraph","inlineContent":[{"text":"After the user has completed or canceled the flow, the completion handler will be called with a result.","type":"text"},{"text":" ","type":"text"},{"text":"On successful authentication the result will contain an instance of ","type":"text"},{"code":"Report","type":"codeVoice"},{"text":" with two optional properties: ","type":"text"},{"code":"accountVerificationReportID","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"transactionReportID","type":"codeVoice"},{"text":".","type":"text"},{"text":" ","type":"text"},{"text":"Both properties will have non-optinal value in case if ","type":"text"},{"code":"reportTypes","type":"codeVoice"},{"text":" parameter has been set to ","type":"text"},{"code":".all","type":"codeVoice"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"Tink.Reports.createReport"},{"text":" method call.","type":"text"},{"text":" ","type":"text"},{"text":"And respectively, if ","type":"text"},{"code":"reportTypes","type":"codeVoice"},{"text":" was set to ","type":"text"},{"code":".transactionReport","type":"codeVoice"},{"text":" only ","type":"text"},{"code":"transactionReportID","type":"codeVoice"},{"text":" will have non-optional value and if ","type":"text"},{"code":"reportTypes","type":"codeVoice"},{"text":" was set to ","type":"text"},{"code":".accountVereficationReport","type":"codeVoice"},{"text":" only ","type":"text"},{"code":"accountVerificationReportID","type":"codeVoice"},{"text":" will have non-optional value.","type":"text"},{"text":" ","type":"text"},{"text":"If something went wrong the result will contain an error.","type":"text"}]},{"type":"codeListing","code":["switch result {","    case .success(let report):","        \/\/ Handle report.transactionReport and report.accountVerificationReportID after successful conn